PORT=8080
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=warehouse_iot

MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Subscribe to both zone and non-zone topic patterns
MQTT_TOPIC=devices/+/+/telemetry,devices/+/telemetry

# A-1-2 room geometry (size / aisle / door / bay checkpoints) is hardcoded from CAD
# survey constants in backend/src/config.js — it MUST stay in sync with the bay
# coordinates, so it is intentionally NOT overridable via SLAM_AREA_* env vars.
# (A stale 20×12 here once clipped every real ~56×36 checkpoint off-canvas → blank map.)
