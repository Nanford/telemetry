PORT=8080
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=warehouse_iot

MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Subscribe to both zone and non-zone topic patterns
MQTT_TOPIC=devices/+/+/telemetry,devices/+/telemetry

# Optional floor metadata for the indoor SLAM map (A-1-2 room only by default).
# Configure both dimensions only when they are known; otherwise the UI derives
# bounds from checkpoint and trail coordinates.
SLAM_AREA_ID=A-1-2
SLAM_AREA_NAME=A-1-2 库房
SLAM_AREA_WIDTH=20
SLAM_AREA_HEIGHT=12
