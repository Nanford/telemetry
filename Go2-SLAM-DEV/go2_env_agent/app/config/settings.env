# Go2 Environment Telemetry Agent Configuration
# Copy to /opt/go2-env-agent/config/settings.env and edit values.

# ---- Device ----
DEVICE_ID=go2_01
DHT_GPIO=D4
INTERVAL_SEC=5

# ---- Positioning ----
# go2_slam | gps
POSITION_SOURCE=go2_slam
GO2_POSE_MODE=sdk2_python
GO2_NET_IFACE=eth0
GO2_POSE_TOPIC=rt/sportmodestate
SLAM_FRAME=map
GO2_POSE_STALE_SEC=2.0

# ---- Point Matching ----
POINTS_FILE=/opt/go2-env-agent/app/config/points.yaml
DWELL_COUNT=3

# ---- Storage ----
SPOOL_DB=/var/lib/go2-env-agent/spool.db

# ---- MQTT ----
MQTT_HOST=broker.example.com
MQTT_PORT=1883
MQTT_TOPIC=devices/go2_01/telemetry
MQTT_STATUS_TOPIC=devices/go2_01/status
MQTT_CLIENT_ID=go2-env-agent-go2_01
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_TLS=0
MQTT_CA_CERT=

# ---- HTTP (optional) ----
HTTP_ENABLE=0
HTTP_ENDPOINT=
HTTP_TOKEN=

# ---- GPS Fallback (only when POSITION_SOURCE=gps) ----
SIM7600_AT_PORT=/dev/ttyUSB2
GNSS_DEFAULT_LAT=30.681732
GNSS_DEFAULT_LON=114.183271
